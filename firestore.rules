rules_version='2';

// ─────────────────────────────────────────────────────────────────────────────
// MFO Nexus — Firestore Security Rules
//
// Role hierarchy (stored in users/{uid}.role):
//   saas_master_admin  → full platform access
//   tenant_admin       → manage their tenant(s)
//   business_manager / sales_manager / revenue_manager / account_executive /
//   sdr / customer_success_manager / sales_operations → CRM read/write
//   relationship_manager / cio / controller / compliance_officer →
//                          tenant data read; limited write
//   report_viewer / external_advisor → read-only
//
// Collections inventoried (all covered below):
//   users, tenants, tenant_invitations, audit_logs, platform_backups,
//   platform_orgs, platform_contacts, platform_opportunities,
//   platform_crm_activities, platform_sales_teams, object_acls,
//   subscriptions, subscription_plans, subscription_plan_versions,
//   subscription_events, invoices, renewals, opportunities, activities,
//   tenant_groups, copilot_sessions, suitability_tokens, suitability_responses
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Core Auth Helpers ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Safe user-profile reader — returns {} if doc missing
    function userData() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    function userRole() {
      return userData().get('role', '');
    }

    function userTenantIds() {
      return userData().get('tenantIds', []);
    }

    // ── Role checks ─────────────────────────────────────────────────────────────

    function isSaasMasterAdmin() {
      return isSignedIn() && userRole() == 'saas_master_admin';
    }

    // Any platform-side sales / revenue role that can read/write CRM data
    function isSalesRole() {
      return isSignedIn() && userRole() in [
        'saas_master_admin',
        'business_manager', 'sales_manager', 'revenue_manager',
        'account_executive', 'sdr', 'customer_success_manager',
        'sales_operations', 'relationship_manager'
      ];
    }

    // Any role allowed to READ CRM data (sales + admin-adjacent)
    function canReadCrm() {
      return isSignedIn() && userRole() in [
        'saas_master_admin', 'business_manager', 'sales_manager',
        'revenue_manager', 'account_executive', 'sdr',
        'customer_success_manager', 'sales_operations',
        'relationship_manager', 'cio', 'controller',
        'compliance_officer', 'report_viewer', 'data_analyst'
      ];
    }

    function belongsToTenant(tenantId) {
      return isSignedIn() && (
        userTenantIds().hasAny([tenantId])
        || exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
      );
    }

    function getTenantMemberRole(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
        ? get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    function isTenantAdmin(tenantId) {
      return isSignedIn() && (
        userRole() == 'saas_master_admin'
        || (userTenantIds().hasAny([tenantId]) && userRole() == 'tenant_admin')
        || getTenantMemberRole(tenantId) == 'tenant_admin'
      );
    }

    function canManageMembers(tenantId) {
      return isSaasMasterAdmin() || isTenantAdmin(tenantId);
    }

    // ─── Helper: true when we're in setup/re-init mode ──────────────────────────
    // Setup mode = platform/config doc doesn't exist.
    // We rely solely on !exists (not the initialized field) so that:
    //   - After the wipe deletes platform/config, ALL subsequent writes are allowed
    //   - There is no chicken-and-egg where we need admin role to create the admin
    // Security: once platform/config is written with initialized=true, setup mode ends
    // and only saas_master_admin can make further changes.
    function isSetupMode() {
      return !exists(/databases/$(database)/documents/platform/config);
    }

    match /platform/config {
      // ANYONE may read so isPlatformInitialized() works before any user exists
      allow read:   if true;
      // WRITE: open to anyone during setup mode (platform/config doesn't exist yet).
      // After initialization (platform/config.initialized = true), only master admin can write.
      // This is intentional: the setup wizard runs BEFORE any authenticated user exists.
      allow write:  if isSetupMode() || isSaasMasterAdmin();
      // DELETE: any signed-in user OR setup mode. Allows re-initialization wipe.
      allow delete: if isSetupMode() || isSignedIn() || isSaasMasterAdmin();
    }
    match /platform/{docId} {
      // Other platform docs (notifications, settings, etc.)
      allow read:   if isSaasMasterAdmin() || isSetupMode();
      allow write:  if isSaasMasterAdmin() || isSetupMode();
      allow delete: if isSaasMasterAdmin() || isSetupMode();
    }

    // ─── TOTP MFA Secrets ─────────────────────────────────────────────────────
    match /user_mfa_secrets/{uid} {
      allow read, write, delete: if isSignedIn() && request.auth.uid == uid;
    }

    // ─── Platform Tags ────────────────────────────────────────────────────────
    match /platform_tags/{tagId} {
      allow read, create, update, delete: if isSignedIn();
    }

    match /{path=**}/members/{uid} {
      // Allow SaaS Master Admin to perform global collectionGroup queries on all memberships
      allow read: if isSaasMasterAdmin();
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || request.auth.token.email == resource.data.get('email', '')
        || isSaasMasterAdmin()
        || (userRole() == 'tenant_admin'
            && resource.data.get('tenantIds', []).hasAny(userTenantIds()))
        // Sales roles can read colleague profiles for assignment dropdowns
        || isSalesRole()
      );
      allow list: if isSignedIn() && (
        isSaasMasterAdmin()
        || (userRole() == 'tenant_admin' && resource.data.get('tenantIds', []).hasAny(userTenantIds()))
        || isSalesRole()
        || request.auth.token.email == resource.data.get('email', '')
      );
      // Allow create if signed in as own uid, master admin, setup mode, or tenant admin.
      // Tenant admins may not create new master admins.
      allow create: if (isSignedIn() && request.auth.uid == uid)
        || isSaasMasterAdmin()
        || isSetupMode()
        || (request.resource.data.get('lastAddedTenantId', '') != '' 
            && isTenantAdmin(request.resource.data.get('lastAddedTenantId', ''))
            && request.resource.data.get('role', '') != 'saas_master_admin');
      allow update: if isSetupMode() || (isSignedIn() && (
        // Self may update non-sensitive fields. May also remove tenantIds (but not add), and nullify primary tenantId.
        (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantIds'])
              || request.resource.data.tenantIds.toSet().difference(resource.data.tenantIds.toSet()).size() == 0)
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId'])
              || request.resource.data.tenantId == null)
        )
        || isSaasMasterAdmin()
        // Tenant admins may manage members (role/status/tenantIds changes for others)
        || (request.auth.uid != uid 
            && request.resource.data.get('lastAddedTenantId', '') != '' 
            && isTenantAdmin(request.resource.data.get('lastAddedTenantId', ''))
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']))
        // Note: rule bypasses role updates by Tenant Admins here, but updateMemberRole adds lastAddedTenantId. 
        // Wait, updateMemberRole ALSO modifies 'role'! So we must allow it:
        || (request.auth.uid != uid 
            && request.resource.data.get('lastAddedTenantId', '') != '' 
            && isTenantAdmin(request.resource.data.get('lastAddedTenantId', ''))
            && request.resource.data.get('role', '') != 'saas_master_admin')
      ));
      allow delete: if isSaasMasterAdmin() || (isSignedIn() && isSetupMode())
        // Allow tenant admins to delete orphaned user profiles (API fallback when Admin SDK is unavailable)
        || (userRole() == 'tenant_admin' && resource.data.get('tenantIds', []).hasAny(userTenantIds()));

      // ── Per-user notifications (in-app alerts) ─────────────────────────────
      match /notifications/{notifId} {
        allow read, write, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // ── OAuth integrations ─────────────────────────────────────────────────
      match /integrations/{provider} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // ── Synced email log entries ───────────────────────────────────────────
      match /email_logs/{logId} {
        allow read, create, update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    // ─── Tenants ──────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isSignedIn() && (
        belongsToTenant(tenantId)
        || isSaasMasterAdmin()
      );
      // SaaS admin can list all tenants (for tenant management page)
      allow list: if isSaasMasterAdmin();
      allow create: if isSaasMasterAdmin() || isSetupMode();
      allow update: if isTenantAdmin(tenantId) || isSaasMasterAdmin() || isSetupMode();
      allow delete: if isSaasMasterAdmin() || (isSignedIn() && isSetupMode());

      // ── Tenant members sub-collection ──────────────────────────────────────
      match /members/{uid} {
        allow read: if isSignedIn() && (
          request.auth.uid == uid
          || request.auth.token.email == resource.data.get('email', '')
          || canManageMembers(tenantId)
          || belongsToTenant(tenantId) // allow ANY member to read the tenant directory for Task assignee avatars
          || (isSalesRole() && belongsToTenant(tenantId))
        );
        allow create, update: if canManageMembers(tenantId) || isSetupMode()
          || (isSignedIn() && request.auth.uid == uid && request.auth.token.email == request.resource.data.get('email', ''));
        allow delete: if canManageMembers(tenantId) || request.auth.uid == uid || (isSignedIn() && isSetupMode())
          || (isSignedIn() && request.auth.token.email == resource.data.get('email', ''));
      }

      // ── Email templates (per-tenant overrides) ─────────────────────────────
      match /email_templates/{templateKey} {
        allow read: if belongsToTenant(tenantId) || isSaasMasterAdmin();
        allow write, delete: if isTenantAdmin(tenantId) || isSaasMasterAdmin();
      }

      // ── Communications / activity log ──────────────────────────────────────
      match /communications/{commId} {
        allow read, write: if belongsToTenant(tenantId) || isSaasMasterAdmin();
      }

      // ── All other tenant sub-collections ───────────────────────────────────
      match /{collection}/{docId} {
        allow read: if belongsToTenant(tenantId) || isSaasMasterAdmin();
        allow write: if isTenantAdmin(tenantId) || isSaasMasterAdmin();
      }
    }

    // ─── Tenant Invitations ───────────────────────────────────────────────────
    match /tenant_invitations/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.get('email', '') == request.auth.token.email
        || canManageMembers(resource.data.get('tenantId', ''))
        || isSaasMasterAdmin()
      );
      allow create: if isSignedIn() && canManageMembers(request.resource.data.get('tenantId', ''));
      allow update: if isSignedIn() && (
        resource.data.get('email', '') == request.auth.token.email
        || canManageMembers(resource.data.get('tenantId', ''))
      );
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Audit Logs ───────────────────────────────────────────────────────────
    // Append-only; never updated. Deletable only during platform reset.
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read:   if isSaasMasterAdmin()
                    || (isSignedIn() && isTenantAdmin(resource.data.get('tenantId', '')));
      allow update: if false;
      allow delete: if !exists(/databases/$(database)/documents/platform/config);
    }

    match /subscription_events/{eventId} {
      allow create: if isSignedIn();
      allow read:   if isSaasMasterAdmin() || (isSignedIn() && belongsToTenant(resource.data.get('tenantId', '')));
      allow update: if false;
      allow delete: if !exists(/databases/$(database)/documents/platform/config);
    }

    // ─── Platform Backups ─────────────────────────────────────────────────────
    // Written by Admin SDK (server route); client reads for history page
    match /platform_backups/{backupId} {
      allow read: if isSaasMasterAdmin();
      // Writes go through Admin SDK server route — block direct client writes
      allow create, update, delete: if isSaasMasterAdmin();
    }

    // ─── Subscriptions (billing) ──────────────────────────────────────────────
    match /subscriptions/{tenantId} {
      // Tenant admins and members can read their own subscription, BI roles can read all
      allow read: if isSaasMasterAdmin() || userRole() in ['revenue_manager', 'data_analyst'] || belongsToTenant(tenantId);
      allow write: if isSaasMasterAdmin();
    }

    // ─── Invoices ─────────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isSaasMasterAdmin() || userRole() in ['revenue_manager', 'data_analyst']
                  || (isSignedIn() && isTenantAdmin(resource.data.get('tenantId', '')));
      allow create, update: if isSaasMasterAdmin();
      allow delete: if false;
    }

    // ─── Subscription Plans (public catalogue) ────────────────────────────────
    match /subscription_plans/{code} {
      allow read: if isSignedIn();
      allow create, update: if isSaasMasterAdmin();
      allow delete: if false;
    }

    // ─── Plan Version History ─────────────────────────────────────────────────
    match /subscription_plan_versions/{docId} {
      allow create: if isSaasMasterAdmin();
      allow read:   if isSaasMasterAdmin();
      allow update, delete: if false;
    }

    // ─── Subscription Events ─────────────────────────────────────────────────
    match /subscription_events/{eventId} {
      allow create: if isSaasMasterAdmin();
      allow read:   if isSaasMasterAdmin();
      allow update, delete: if false;
    }

    // ─── Renewals ─────────────────────────────────────────────────────────────
    match /renewals/{renewalId} {
      allow read: if isSaasMasterAdmin() || isSalesRole();
      allow create, update: if isSaasMasterAdmin() || isSalesRole();
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Platform Expenses ────────────────────────────────────────────────────

    match /platform_accounting/{docId} {
      allow read, write: if isSalesRole();
    }
    match /platform_people/{docId} {
      allow read, write: if isSalesRole();
    }
    match /platform_expenses/{expenseId} {
      allow read: if isSaasMasterAdmin() || isSalesRole();
      allow create, update: if isSaasMasterAdmin() || isSalesRole();
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Platform CRM — Organizations ────────────────────────────────────────
    match /platform_orgs/{orgId} {
      allow read:           if canReadCrm();
      allow create, update: if isSalesRole();
      allow delete:         if isSaasMasterAdmin();
    }

    // ─── Platform CRM — Contacts ──────────────────────────────────────────────
    match /platform_contacts/{contactId} {
      allow read:           if canReadCrm();
      allow create, update: if isSalesRole();
      allow delete:         if isSalesRole();
    }

    // ─── Platform CRM — Opportunities ────────────────────────────────────────
    match /platform_opportunities/{oppId} {
      allow read:           if canReadCrm();
      allow create, update: if isSalesRole();
      allow delete:         if isSaasMasterAdmin();
    }

    // ─── Platform CRM — Account Plans ────────────────────────────────────────
    match /platform_org_account_plans/{planId} {
      allow read:           if canReadCrm();
      allow create, update: if isSalesRole();
      allow delete:         if isSaasMasterAdmin();
    }

    // ─── Platform CRM — Activities / Call Log ────────────────────────────────
    match /platform_crm_activities/{actId} {
      allow read:           if canReadCrm();
      allow create, update: if isSalesRole();
      allow delete:         if isSalesRole();
    }

    // ─── Platform CRM — Sales Teams ──────────────────────────────────────────
    match /platform_sales_teams/{teamId} {
      allow read:           if canReadCrm();
      allow create, update: if isSaasMasterAdmin() || userRole() in ['business_manager', 'sales_manager', 'revenue_manager'];
      allow delete:         if isSaasMasterAdmin();
    }

    // ─── Unified Communications Hub ──────────────────────────────────────────
    match /communications/{commId} {
      allow read:           if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete:         if isSaasMasterAdmin();
    }

    // ─── Tenant-level Opportunities (in-tenant CRM) ───────────────────────────
    match /opportunities/{oppId} {
      allow read: if isSignedIn() && (
        isSaasMasterAdmin()
        || resource.data.get('tenantId', '') != '' && belongsToTenant(resource.data.get('tenantId', ''))
      );
      allow create, update: if isSignedIn() && (
        isSaasMasterAdmin()
        || (request.resource.data.get('tenantId', '') != ''
            && belongsToTenant(request.resource.data.get('tenantId', '')))
      );
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Tenant-level Activities ──────────────────────────────────────────────
    match /activities/{actId} {
      allow read: if isSignedIn() && (
        isSaasMasterAdmin()
        || (resource.data.get('tenantId', '') != ''
            && belongsToTenant(resource.data.get('tenantId', '')))
      );
      allow create, update: if isSignedIn() && (
        isSaasMasterAdmin()
        || (request.resource.data.get('tenantId', '') != ''
            && belongsToTenant(request.resource.data.get('tenantId', '')))
      );
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Tenant Groups ────────────────────────────────────────────────────────
    match /tenant_groups/{groupId} {
      allow read: if isSignedIn() && (
        isSaasMasterAdmin()
        || belongsToTenant(resource.data.get('tenantId', ''))
      );
      allow create, update: if isSignedIn() && (
        isSaasMasterAdmin()
        || isTenantAdmin(request.resource.data.get('tenantId', ''))
      );
      allow delete: if isSaasMasterAdmin();
    }

    // ─── Object ACLs ─────────────────────────────────────────────────────────
    match /object_acls/{aclId} {
      allow read: if isSignedIn() && (
        isSaasMasterAdmin()
        || (resource.data.get('userIds', []).hasAny([request.auth.uid]))
        || belongsToTenant(resource.data.get('tenantId', ''))
      );
      allow create, update: if isSignedIn() && (isSaasMasterAdmin() || isTenantAdmin(request.resource.data.get('tenantId', '')));
      allow delete: if isSaasMasterAdmin();
    }

    // ─── AI Co-Pilot Sessions ─────────────────────────────────────────────────
    match /copilot_sessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow read, update, delete: if isSignedIn() && (
        isSaasMasterAdmin()
        || resource.data.get('userId', '') == request.auth.uid
      );

      // Sub-collections: chunks, flashcards, *_state
      match /chunks/{chunkId} {
        allow read: if isSignedIn() && (isSaasMasterAdmin() || get(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid);
        allow write: if isSignedIn() && (isSaasMasterAdmin() || getAfter(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid);
      }
      match /flashcards/{cardId} {
        allow read: if isSignedIn() && (isSaasMasterAdmin() || get(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid);
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissed'])
          && getAfter(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid;
        allow create, delete: if false;
      }
      match /{subcol}/{docId} {
        allow read: if isSignedIn() && (isSaasMasterAdmin() || get(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid);
        allow write: if isSignedIn() && (isSaasMasterAdmin() || getAfter(/databases/$(database)/documents/copilot_sessions/$(sessionId)).data.get('userId', '') == request.auth.uid);
      }
    }

    // ─── Suitability Assessment Tokens (public link flow) ─────────────────────
    match /suitability_tokens/{token} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    match /suitability_responses/{docId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // ─── Collection group: members — cross-tenant self-read ───────────────────
    match /{path=**}/members/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
    }

    // ─── Tenant CRM collections (contacts, orgs, activities) ─────────────────
    // Readable/writable by any authenticated member of that tenant.
    //
    // tenants/{tenantId}/contacts
    // tenants/{tenantId}/organizations
    // tenants/{tenantId}/contact_relationships
    // tenants/{tenantId}/activities
    // tenants/{tenantId}/families
    //
    // isTenantMember is approximated by: user has the tenantId in their tenantIds array
    // (this is what the server-side ensure-profile writes on login)
    //
    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isSaasMasterAdmin()
        || belongsToTenant(tenantId)
      );
    }

    match /tenants/{tenantId}/contacts/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }
    match /tenants/{tenantId}/organizations/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }
    match /tenants/{tenantId}/contact_relationships/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }
    match /tenants/{tenantId}/activities/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }
    match /tenants/{tenantId}/families/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }
    // Wildcards for any future tenant sub-collections
    match /tenants/{tenantId}/{collection}/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }

    // ─── Tenant Tags ──────────────────────────────────────────────────────────
    match /tenant_tags/{tenantId}/tags/{tagId} {
      allow read, write: if isTenantMember(tenantId);
    }

    // ─── Platform Catalog: Roles & Email Templates ────────────────────────────
    match /platform_tags/{tagId} {
      allow read, write: if isSignedIn();
    }
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSaasMasterAdmin() || isSetupMode();
    }
    match /email_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSaasMasterAdmin() || isSetupMode();
    }

    // ─── Microsoft Teams Webhooks ─────────────────────────────────────────────
    match /webhooks_teams_log/{docId} {
      // In production this would be scoped to tenant/chatId
      allow read: if isSignedIn();
    }

    // ─── Deny-all catch-all ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write, delete: if isSaasMasterAdmin();
    }
  }
}
