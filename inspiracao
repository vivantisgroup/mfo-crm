      Dados do Cliente:
      ${clientContext}
    `;

    // Chamada à API
    const payload = {
        contents: [{ parts: [{ text: prompt }] }],
        systemInstruction: { parts: [{ text: "Gere o output exclusivamente no formato JSON requisitado, sem formatações adicionais ou markdown." }] },
        generationConfig: {
            responseMimeType: "application/json",
            responseSchema: {
                type: "OBJECT",
                properties: {
                    generalGuideline: { type: "STRING", description: "Parecer geral inicial do comitê sobre a situação do cliente." },
                    scenarios: {
                        type: "ARRAY",
                        items: {
                            type: "OBJECT",
                            properties: {
                                name: { type: "STRING", description: "Obrigatório ser: Conservador, Moderado, ou Agressivo" },
                                assetAllocation: { type: "STRING", description: "Sugestão detalhada de % de alocação de ativos (ex: Renda Fixa, Ações Globais, Alternativos, Real Estate)." },
                                taxAndSuccessionStrategy: { type: "STRING", description: "Ação exata sobre estruturas (Trust, PIC), recomendações sobre distribuição em vida e blindagem fiscal considerando os países em que o cliente viverá." },
