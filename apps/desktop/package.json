{
  "name": "@mfo-crm/desktop",
  "version": "1.0.0",
  "description": "MFO Nexus Desktop — Electron shell with CRM + WhatsApp Web split panel",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vivantisgroup.mfo-nexus",
    "productName": "MFO Nexus",
    "copyright": "Copyright © 2026 Vivantis Group",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico"
    }
  }
}
