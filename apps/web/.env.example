# ─── MFO-CRM Local Development Environment Variables ─────────────────────────
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit it.
#
# All NEXT_PUBLIC_ vars are exposed to the browser.
# All others are server-only (API routes only).
# ─────────────────────────────────────────────────────────────────────────────

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Microsoft 365 OAuth (Azure App Registration) ──────────────────────────────
# Azure Portal → App Registrations → Your App → Overview
MICROSOFT_CLIENT_ID=
# Azure Portal → App Registrations → Your App → Certificates & secrets
MICROSOFT_CLIENT_SECRET=
# Use 'common' for multi-tenant apps, or your specific tenant/directory ID
MICROSOFT_TENANT_ID=common

# ── Google Workspace OAuth ─────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Firebase Admin SDK ─────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE JSON as a single line (minified). 
# The private_key field must use literal \n characters (not actual newlines).
FIREBASE_ADMIN_SDK_JSON=
