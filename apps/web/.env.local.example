# ─── Firebase Client (required for browser) ───────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Firebase Admin SDK (required for API routes only) ────────────────────────
#
# OPTION A — Service Account JSON (recommended for Vercel production)
# ----------
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Open the downloaded file in a text editor
# 4. Minify it to ONE LINE (no real newlines — that's the most common issue)
# 5. For private_key specifically, replace real newlines with the literal \n
#
# Quick CLI minify (PowerShell):
#   (Get-Content service-account.json -Raw) -replace '[\r\n]+', '' | Set-Clipboard
#
# Quick CLI minify (bash/macOS):
#   cat service-account.json | tr -d '\n' | pbcopy
#
# Then paste the single-line result here:
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...paste key here with \\n instead of real newlines...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}

# ─── OPTION B — Application Default Credentials (local development only) ──────
# Leave FIREBASE_ADMIN_SDK_JSON unset and instead run:
#   gcloud auth application-default login
# This lets the Admin SDK use your gcloud credentials automatically.
# NOTE: ADC does NOT work on Vercel — use OPTION A for production.

# ─── Other settings ────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
